{
  "$schema": "https://raw.githubusercontent.com/nicepkg/vscode-tauri/main/schemas/config.schema.json",
  "productName": "Files Explorer",
  "version": "0.2.0",
  "identifier": "com.files-explorer.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Files Explorer",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "dragDropEnabled": true,
        "visible": false,
        "devtools": true
      },
      {
        "label": "splashscreen",
        "title": "Files Explorer",
        "width": 360,
        "height": 320,
        "resizable": false,
        "decorations": false,
        "center": true,
        "alwaysOnTop": true,
        "url": "/splashscreen.html"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "endpoints": [
        "https://gitee.com/hhyd/files-explorer/raw/main/updater.json",
        "https://raw.githubusercontent.com/chaoyingLi/files-explorer/main/updater.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY0RDY3OTYxN0M0MUU4MEYKUldRUDZFRjhZWG5XOUdUNE9WQVRvaTkza2J1WW4yK0MvYUdRaDNVdFNGMjYwaW9oRi9ydyt6MmoK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "copyright": "",
    "category": "Utility",
    "shortDescription": "Cross-platform file manager",
    "longDescription": "Files Explorer \u2014 a modern, cross-platform file manager built with Tauri.",
    "windows": {
      "wix": null,
      "nsis": null
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "linux": {}
  }
}
